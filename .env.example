# ══════════════════════════════════════════════════════════════════════════════
# CHỌN PROVIDER:
#   gemini  → MIỄN PHÍ hoàn toàn (khuyến nghị)
#   openai  → Trả phí (~$0.10/lần chạy đầu)
# ══════════════════════════════════════════════════════════════════════════════
AI_PROVIDER=gemini

# ── Gemini (FREE) ─────────────────────────────────────────────────────────────
# Lấy key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...your-gemini-key-here...

# Nếu dùng AI_PROVIDER=openai mới cần key này:
OPENAI_API_KEY=sk-...your-openai-key-here...

# ── Pipeline settings ─────────────────────────────────────────────────────────
MAX_ARTICLES=50
ARTICLES_PER_PAGE=100
ARTICLES_DIR=./articles
DELTA_DB_PATH=./data/delta.db
CHROMA_DB_PATH=./data/chroma

# ── Model config ──────────────────────────────────────────────────────────────
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=models/text-embedding-004
OPENAI_MODEL=gpt-4o-mini
VECTOR_STORE_NAME=optisigns-support-docs
ASSISTANT_NAME=OptiBot

# ── Zendesk ───────────────────────────────────────────────────────────────────
ZENDESK_BASE_URL=https://support.optisigns.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
